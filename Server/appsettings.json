{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cmri": {
    "Transport": "Serial",
    "NodeAddress": 0,
    "NodeType": "SMINI",
    "TimeoutMs": 3000,
    "Delay": 0,
    "MaxBuf": 64,
    "Memory": {
      "MockInputs": [ 0, 8, 0 ]
    },
    "Tcp": {
      "Host": "CmriPi",
      "Port": 3333
    },
    "Serial": {
      "PortName": "/dev/ttyUSB0",
      "Baud100": 96
    }
  },
  "Layout": {
    "FilePath": "Data/currentLayout.json"
  },
  "AllowedHosts": "*"
}
